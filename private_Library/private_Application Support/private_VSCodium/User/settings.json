{
  "workbench.colorTheme": "Atom One Dark",
  "editor.fontSize": 13,
  "editor.formatOnSave": true,
  "files.autoSave": "onFocusChange",
  "editor.fontFamily": "'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "editor.tabSize": 2,
  "editor.formatOnPaste": true,
  "editor.autoIndentOnPaste": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.emptySelectionClipboard": false,
  "editor.guides.bracketPairs": true,
  "editor.hover.showLongLineWarning": false,
  "editor.lightbulb.enabled": "off",
  "editor.linkedEditing": true,
  "editor.renderWhitespace": "boundary",
  "editor.smoothScrolling": true,
  "editor.tabCompletion": "on",
  "editor.wordWrapColumn": 96,
  "editor.experimentalGpuAcceleration": "on",
  "editor.find.addExtraSpaceOnTop": false,
  "editor.fontLigatures": true,
  "editor.minimap.enabled": false,
  "editor.suggest.localityBonus": true,
  "files.autoSaveWhenNoErrors": true,
  "files.autoSaveWorkspaceFilesOnly": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "workbench.list.smoothScrolling": true,
  "workbench.remoteIndicator.showExtensionRecommendations": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none",
  "workbench.commandPalette.showAskInChat": false,
  "workbench.notifications.position": "top-right",
  "workbench.editor.highlightModifiedTabs": true,
  "window.autoDetectColorScheme": true,
  "window.nativeTabs": true,
  "window.newWindowDimensions": "maximized",
  "chat.agent.enabled": false,
  "chat.tools.edits.autoApprove": {
    "**/*": false,
  },
  "chat.tools.terminal.enableAutoApprove": false,
  "chat.tools.terminal.blockDetectedFileWrites": "all",
  "search.defaultViewMode": "tree",
  "debug.toolBarLocation": "docked",
  "scm.defaultViewMode": "tree",
  "scm.diffDecorationsIgnoreTrimWhitespace": "true",
  "extensions.ignoreRecommendations": true,
  "terminal.external.linuxExec": "wezterm",
  "terminal.external.osxExec": "wezterm",
  "terminal.external.windowsExec": "wt.exe",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.hideOnStartup": "whenEmpty",
  "terminal.integrated.macOptionIsMeta": true,
  "terminal.integrated.smoothScrolling": true,
  "telemetry.feedback.enabled": false,
  "git.autoStash": true,
  "github.gitProtocol": "ssh",
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "js/ts.preferences.quoteStyle": "double",
  "js/ts.format.semicolons": "remove",
  "js/ts.reportStyleChecksAsWarnings": false,
  "js/ts.implicitProjectConfig.checkJs": true,
  "js/ts.implicitProjectConfig.target": "ES2022",
  "js/ts.preferGoToSourceDefinition": true,
  "js/ts.suggest.autoImports": false,
  "js/ts.suggest.jsdoc.enabled": false,
  "workbench.preferredDarkColorTheme": "Atom One Dark",
}
